    "autonomous:next:write": "tsx scripts/autonomous/next-best-task-loop.ts --write",
    "autonomous:cycle": "tsx scripts/autonomous/run-autonomous-cycle.ts",
    "autonomous:execute": "tsx scripts/autonomous/execute-autonomous-task.ts",
    "autonomous:health": "tsx scripts/autonomous/health.ts",
    "autonomous:level-b": "tsx scripts/autonomous/level-b.ts",
    "autonomous:level-b:write": "tsx scripts/autonomous/level-b.ts --write",
    "autonomous:verify": "tsx scripts/autonomous/verify-autonomous-os.ts"
  },
  "dependencies": {
    "@langchain/core": "^1.1.42",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@tavily/core": "^0.7.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.542.0",
    "openai": "^6.34.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.11",
    "zustand": "^5.0.8"
  },
  "overrides": {
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
