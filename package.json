    "ah:review": "tsx scripts/codex/ah-command.ts review",
    "ah:ui": "tsx scripts/codex/ah-command.ts ui",
    "ah:ship": "tsx scripts/codex/ah-command.ts ship",
    "ah:skills": "tsx scripts/codex/ah-command.ts skills",
