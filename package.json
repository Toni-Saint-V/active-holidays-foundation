    "verify:kit:copy": "tsx scripts/verify-kit-copy.ts",
    "verify:kit:motion": "tsx scripts/verify-kit-motion.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify:agent-stack": "tsx scripts/verify-agent-stack.ts",
    "audit:m1-scope": "tsx scripts/audit-m1-scope.ts",
